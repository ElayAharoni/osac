# BFF server port (default: 3001)
PORT=3001

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# API mode:
#   mock — BFF serves built-in mock data (no upstream required)
#   dev  — BFF proxies to a real fulfillment API at FULFILLMENT_API_URL
OSAC_API_MODE=mock

# Required when OSAC_API_MODE=dev
# FULFILLMENT_API_URL=https://fulfillment.example.com
